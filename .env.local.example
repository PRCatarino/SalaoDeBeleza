# Na Vercel: Settings → Environment Variables (Production + Preview) → Redeploy.
# O app NÃO usa NEXT_PUBLIC_SUPABASE_* no código — só DATABASE_URL + AUTH_SECRET.

# URL do site (sem barra no final). Opcional.
NEXT_PUBLIC_SITE_URL=https://SEU_PROJETO.vercel.app

# PostgreSQL — connection string completa.
# Supabase na Vercel: use o pooler (IPv4), porta 6543, com ssl na URL, ex.:
# postgresql://postgres.PROJECT_REF:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?sslmode=require
# VPS sem SSL: postgresql://user:pass@IP:5432/db  e defina DATABASE_SSL=false
DATABASE_URL=postgresql://salao_app:SUA_SENHA@SEU_IP:5432/seu_app

# Força TLS (padrão: ligado para *.supabase.co, *.neon.tech, pooler). Postgres local: false
# DATABASE_SSL=false

# Máximo de conexões por instância serverless (padrão na Vercel: 1)
# DATABASE_POOL_MAX=1

# JWT / sessão (min. 32 chars). Gere com: openssl rand -base64 32
AUTH_SECRET=cole_aqui_uma_string_aleatoria_longa
