# URL do site (sem barra no final). Obrigatório na Vercel (Environment Variables).
# Sem isto, cadastro no localhost gera link de e-mail com redirect_to=localhost e “não abre” no telemóvel.
NEXT_PUBLIC_SITE_URL=https://SEU_PROJETO.vercel.app

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Chave service_role (Settings → API). Só no servidor — NUNCA NEXT_PUBLIC.
# Obrigatória para limite de tentativas de cadastro + bloqueio de e-mail temporário na API.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Use uma das duas (a publishable substitui a anon nas contas novas):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
